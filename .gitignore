.pio/
.vscode/
*.bin
*.elf
*.map
# local SD staging copies (anchored to repo root; case matters on macOS ignorecase)
/sdcard-staging/
/NeoDeck.bin
# DO ship the web-flasher images (lives under docs/ for GitHub Pages) — keep this
# exception LAST so nothing above re-ignores it
!docs/firmware/*.bin
# Local secrets — never commit real keys/creds
data/config.json
data/keys/*
!data/keys/.gitkeep
data/ca/*
!data/ca/.gitkeep
